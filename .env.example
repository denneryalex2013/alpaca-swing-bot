# Copy this file to .env and fill in your real values
# .env is gitignored and never committed

# DigitalOcean — https://cloud.digitalocean.com/account/api/tokens
DO_TOKEN=

# Alpaca — https://console.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# GitHub — https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=

# Discord — Server > channel > Edit Channel > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Pre-filter thresholds (optional — defaults shown)
VIX_BUY_BLOCK_THRESHOLD=30.0  # block buys when VIX exceeds this (high market stress)
